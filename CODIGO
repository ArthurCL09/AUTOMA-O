import tkinter as tk


palavras = ["ARBITRO", "ARQUIBANCADA", "PALMER"]

indice = 0  

def trocar_palavra(event):
    global indice
    indice = (indice + 1) % len(palavras)
    label.config(text=palavras[indice])


janela = tk.Tk()
janela.title("JOGO DA MIMICA")
janela.geometry("400x200")


label = tk.Label(janela, text=palavras[indice], font=("Arial", 40))
label.pack(expand=True)


janela.bind("<Button-1>", trocar_palavra)

janela.mainloop()
